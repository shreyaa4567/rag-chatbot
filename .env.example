# Copy this file to .env and adjust values as needed.
# Real environment variables always override these.

# ─── Target / crawler ───────────────────────────────────────────
TARGET_URL=https://home.iitd.ac.in/
MAX_PAGES=150
DELAY_SECONDS=1.0
REQUEST_TIMEOUT=10

# ─── Ollama models ──────────────────────────────────────────────
LLM_MODEL=gemma3:4b
EMBED_MODEL=nomic-embed-text
OLLAMA_HOST=http://127.0.0.1:11434

# ─── Paths ──────────────────────────────────────────────────────
DATA_DIR=data
CHROMA_DIR=chroma_db
LOG_DIR=logs

# ─── Server / security ──────────────────────────────────────────
# Origin of the ASP.NET WebForms frontend (used to restrict CORS).
FRONTEND_ORIGIN=http://localhost:44300
HOST=0.0.0.0
PORT=5000
DEBUG=false

# Set to true to serve via Waitress (production WSGI server for Windows).
USE_WAITRESS=false

# ─── Logging ────────────────────────────────────────────────────
LOG_LEVEL=INFO
